{
  "name": "@mysten/dapp-kit-core",
  "author": "Mysten Labs <build@mystenlabs.com>",
  "description": "Framework-agnostic toolkit for building decentralized applications on Sui.",
  "homepage": "https://sdk.mystenlabs.com/sui",
  "version": "1.1.4",
  "license": "Apache-2.0",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "web"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./web": {
      "types": "./dist/web/index.d.mts",
      "import": "./dist/web/index.mjs",
      "default": "./dist/web/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MystenLabs/ts-sdks.git"
  },
  "bugs": {
    "url": "https://github.com/MystenLabs/ts-sdks/issues/new"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@storybook/web-components": "^10.1.11",
    "@storybook/web-components-vite": "^10.1.11",
    "storybook": "^10.2.12",
    "tsdown": "0.20.0-beta.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17",
    "@mysten/sui": "^2.6.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "@lit-labs/scoped-registry-mixin": "^1.0.4",
    "@lit/task": "^1.0.3",
    "@nanostores/lit": "^0.2.3",
    "@wallet-standard/ui": "^1.0.1",
    "@wallet-standard/ui-registry": "^1.0.1",
    "@webcomponents/scoped-custom-element-registry": "^0.0.10",
    "lit": "^3.3.2",
    "nanostores": "^1.1.0",
    "@mysten/slush-wallet": "^1.0.2",
    "@mysten/utils": "^0.3.1",
    "@mysten/wallet-standard": "^0.20.1"
  },
  "peerDependencies": {
    "@mysten/sui": "^2.6.0"
  },
  "scripts": {
    "clean": "rm -rf tsconfig.tsbuildinfo ./dist",
    "build": "pnpm typecheck && tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "tsdown --watch",
    "prettier:check": "prettier -c --ignore-unknown .",
    "prettier:fix": "prettier -w --ignore-unknown .",
    "oxlint:check": "oxlint  .",
    "oxlint:fix": "oxlint --fix",
    "lint": "pnpm run oxlint:check && pnpm run prettier:check",
    "lint:fix": "pnpm run oxlint:fix && pnpm run prettier:fix",
    "test": "pnpm test:typecheck && pnpm vitest run",
    "test:typecheck": "tsc -b ./test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  }
}