{
  "name": "@eveworld/sui-pod-zk",
  "version": "0.0.1",
  "private": true,
  "description": "PoC of zk proximity verification",
  "scripts": {
    "move:init": "bash bin/init-move-project.sh",
    "move:clean": "bash bin/clean-move-projects.sh",
    "move:build": "bash bin/build-move-projects.sh",
    "move:test": "bash bin/test-move-projects.sh",
    "move:publish": "bash bin/publish-move-project.sh",
    "move:run": "node --loader ts-node/esm bin/run-script.ts",
    "sui:install": "chmod +x bin/install-sui.sh && ./bin/install-sui.sh",
    "sui:localnet:start": "bash bin/start-local-sui-network.sh",
    "sui:localnet:stop": "bash bin/stop-local-sui-network.sh",
    "circuit:fetch-ptau:off-chain": "tsx src/off-chain/circuits/utils/fetchPtauOffChain.ts",
    "circuit:fetch-ptau:on-chain": "tsx src/shared/utils/fetchPtauOnChain.ts",
    "circuit:compile:off-chain": "tsx src/off-chain/circuits/utils/compileCircuits.ts all",
    "circuit:compile:on-chain": "tsx src/on-chain/circuits/utils/compileCircuits.ts all",
    "rust:vkey-serializer:fetch": "tsx scripts/fetchRustVKeySerializer.ts",
    "rust:vkey-serializer:build": "tsx scripts/buildRustVKeySerializer.ts",
    "serialize:vkey": "tsx scripts/serializeVKeyForSui.ts",
    "move:test:generate": "tsx scripts/generateMoveTestData.ts",
    "move:test:generate:location": "tsx scripts/generateLocationMoveTests.ts",
    "move:test:generate:proof": "tsx scripts/generate-move-test-proof-data.ts",
    "generate-auth-key": "tsx scripts/generateAuthKey.ts",
    "generate-ed25519-key": "tsx scripts/generateEd25519Key.ts",
    "clean": "tsx scripts/clean.ts",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:timings": "jest --runInBand --forceExit test/proofs/proofGeneration.spec.ts 2>&1 | tsx scripts/extractTimings.ts"
  },
  "keywords": [
    "eve",
    "frontier",
    "sui",
    "move",
    "zk",
    "groth16",
    "pod",
    "gpcircuits"
  ],
  "author": "CCP Games",
  "license": "MIT",
  "dependencies": {
    "@electron-labs/sha512": "^1.0.4",
    "@mysten/sui": "^1.45.2",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "@pcd/gpc": "^0.4.1",
    "@pcd/gpcircuits": "^0.5.1",
    "@pcd/pcd-types": "^0.15.0",
    "@pcd/pod": "^0.5.1",
    "@pcd/util": "^0.9.0",
    "@types/debug": "^4.1.12",
    "@types/lodash": "^4.17.21",
    "@types/snarkjs": "^0.7.9",
    "@zk-kit/imt": "2.0.0-beta.8",
    "dotenv": "^17.2.3",
    "poseidon-lite": "^0.3.0",
    "snarkjs": "^0.7.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@semaphore-protocol/identity": "^4.14.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@zk-kit/binary-merkle-root.circom": "^1.0.0",
    "babel-jest": "^29.7.0",
    "circomlib": "^2.0.5",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0"
  }
}
